{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Antinote",
  "version": "0.1.2",
  "identifier": "com.honganh.antinote-linux",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Antinote",
        "width": 400,
        "height": 400,
        "minWidth": 360,
        "minHeight": 360,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
